{
  "name": "loto-cms",
  "version": "1.1.0",
  "type": "module",
  "description": "LotoCMS 是一款基于Node、Express5、MySQL、Vue3研发的高质量实用型CMS系统。",
  "keywords": [
    "\"CMS\""
  ],
  "main": "dist/app.js",
  "scripts": {
    "clean": "node --input-type=module -e \"import fs from 'node:fs';fs.rmSync('dist',{recursive:true,force:true});\"",
    "build:entry": "babel app.js --out-file dist/app.js",
    "build:app": "babel app --out-dir dist/app --extensions .js --copy-files",
    "build:config": "babel config --out-dir dist/config --extensions .js --copy-files",
    "copy:public": "node --input-type=module -e \"import fs from 'node:fs';fs.cpSync('public','dist/public',{recursive:true});\"",
    "copy:meta": "node --input-type=module -e \"import fs from 'node:fs';fs.copyFileSync('package.json','dist/package.json');\"",
    "build": "npm run clean && npm run build:entry && npm run build:app && npm run build:config && npm run copy:public && npm run copy:meta",
    "build:prd": "npm run build",
    "build:prd:skip-clean": "npm run build:entry && npm run build:app && npm run build:config && npm run copy:public && npm run copy:meta",
    "watch:entry": "babel app.js --out-file dist/app.js --watch",
    "watch:app": "babel app --out-dir dist/app --extensions .js --copy-files --watch",
    "watch:config": "babel config --out-dir dist/config --extensions .js --copy-files --watch",
    "dev": "npm run build && concurrently -k \"npm:watch:entry\" \"npm:watch:app\" \"npm:watch:config\" \"node --env-file=.env.dev --watch dist/app.js\"",
    "start": "node dist/app.js",
    "start:prd": "node --env-file=.env.prd dist/app.js",
    "prd": "npm run build:prd && npm run start:prd",
    "logs:ensure": "node --input-type=module -e \"import fs from 'node:fs';fs.mkdirSync('logs',{recursive:true});\"",
    "pm2:start": "npm run logs:ensure && npx pm2 start ecosystem.config.cjs --env production",
    "pm2:stop": "npx pm2 stop loto-cms",
    "pm2:restart": "npx pm2 restart loto-cms --update-env",
    "pm2:reload": "npx pm2 reload loto-cms --update-env",
    "pm2:delete": "npx pm2 delete loto-cms",
    "pm2:status": "npx pm2 status loto-cms",
    "pm2:logs": "npx pm2 logs loto-cms --lines 200",
    "pm2:save": "npx pm2 save",
    "pm2:log:install": "npx pm2 install pm2-logrotate",
    "pm2:log:config": "node scripts/pm2-logrotate-config.mjs",
    "pm2:log:status": "npx pm2 conf pm2-logrotate",
    "pm2:log:setup": "npm run pm2:logrotate:install && npm run pm2:logrotate:config && npm run pm2:logrotate:status",
    "prod:deploy": "npm run build:prd && npm run pm2:start",
    "prod:restart": "npm run build:prd:skip-clean && npm run pm2:restart",
    "check": "npm audit",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "homepage": "https://github.com/lotocms/loto-cms#readme",
  "bugs": {
    "url": "https://github.com/lotocms/loto-cms/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lotocms/loto-cms.git"
  },
  "license": "MIT",
  "author": "lanbery@gmail.com",
  "directories": {
    "doc": "docs"
  },
  "dependencies": {
    "@lotomic/chanjs": "file:../loto-chanjs",
    "art-template": "^4.13.4",
    "axios": "^1.13.5",
    "bcryptjs": "^3.0.3",
    "body-parser": "^2.2.2",
    "cheerio": "^1.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.19",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-art-template": "^1.0.1",
    "express-safe": "^1.0.9",
    "iconv-lite": "^0.7.2",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "mitt": "^3.0.1",
    "morgan": "^1.10.1",
    "multer": "^2.1.0",
    "mysql2": "^3.18.2",
    "nodemailer": "^8.0.1",
    "qiniu": "^7.15.1",
    "schedule": "^0.5.0",
    "serve-favicon": "^2.5.1",
    "xml2js": "^0.6.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1"
  }
}